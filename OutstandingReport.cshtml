@page
@model PHARMACY.Pages.Billing.OutstandingReportModel
@{
    ViewData["Title"] = "Outstanding Invoices Report";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-6 text-warning mb-1"><i class="fas fa-file-invoice-dollar me-2"></i>Outstanding Invoices Report</h1>
                    <p class="lead mb-0">Summary of all pending customer payments</p>
                </div>
                <div>
                    <button class="btn btn-outline-warning" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>Print Report
                    </button>
                    <a href="/" class="btn btn-outline-secondary">
                        <i class="fas fa-home me-2"></i>Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>
    </div>

<!-- Filter Section -->
<div class="row mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="fas fa-filter me-2"></i>Filter Options</h5>
            </div>
            <div class="card-body">
                <form method="get" class="row g-3">
                    <div class="col-md-3">
                        <label class="form-label">Customer</label>
                        <select class="form-select" asp-for="CustomerFilter">
                            <option value="">All Customers</option>
                            @foreach (var customer in Model.Customers)
                            {
                                <option value="@customer.CustomerId">@customer.CustomerName</option>
                            }
                        </select>
                    </div>

                    <!-- Invoice Date Filters -->
                    <div class="col-md-2">
                        <label class="form-label">From Date</label>
                        <input type="date" class="form-control" asp-for="FromDate" />
                    </div>
                    @* <div class="col-md-2">
                        <label class="form-label">Invoice Date To</label>
                        <input type="date" class="form-control" asp-for="ToDate" />
                    </div> *@

                    <!-- Due Date Filters -->
                    @* <div class="col-md-2">
                        <label class="form-label">Due Date From</label>
                        <input type="date" class="form-control" asp-for="DueDateFrom" />
                    </div> *@
                    <div class="col-md-2">
                        <label class="form-label">To Date</label>
                        <input type="date" class="form-control" asp-for="DueDateTo" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <button type="submit" class="btn btn-warning me-2">
                            <i class="fas fa-search me-1"></i>Filter
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-lg-6 mb-4">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-dark-50">Total Outstanding</h6>
                            <h2 class="fw-bold">LKR @Model.TotalOutstanding.ToString("N2")</h2>
                        </div>
                        <i class="fas fa-file-invoice-dollar fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer bg-warning bg-opacity-25">
                    <small class="text-dark">
                        <i class="fas fa-info-circle me-1"></i>
                        @Model.TotalInvoices invoices
                    </small>
                </div>
            </div>
        </div>

    <!-- Main Report Table -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-list-alt me-2"></i>Outstanding Invoices Details</h5>
                    <small class="text-dark">Showing @Model.OutstandingInvoices.Count invoices</small>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm" id="outstandingTable">
                            <thead class="table-warning">
                                <tr>
                                    <th>Invoice No</th>
                                    <th>Customer</th>
                                    <th class="text-end">Invoice Date</th>
                                    <th class="text-end">Due Date</th>
                                    <th class="text-end">Days</th>
                                    <th class="text-end">Invoice Value</th>
                                    <th class="text-end">Paid</th>
                                    <th class="text-end">Returns</th>
                                    <th class="text-end">Net Value</th>
                                    <th class="text-end">Balance</th>
                                    <th class="text-end">Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var invoice in Model.OutstandingInvoices)
                                {
                                    var daysOverdue = (DateTime.Today - invoice.DueDate).Days;
                                    var statusClass = daysOverdue > 90 ? "danger" :
                                    daysOverdue > 60 ? "warning" :
                                    daysOverdue > 30 ? "info" : "success";

                                    <tr>
                                        <td>
                                            <strong>@invoice.InvoiceNumber</strong>
                                            <div class="text-muted small">@invoice.InvoiceType</div>
                                        </td>
                                        <td>
                                            <div>@invoice.CustomerName</div>
                                            <div class="text-muted small">@invoice.CustomerPhone</div>
                                            @if (!string.IsNullOrEmpty(invoice.CustomerAddress))
                                            {
                                                <div class="text-muted small">@invoice.CustomerAddress</div>
                                            }
                                        </td>
                                        <td class="text-end">@invoice.InvoiceDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="text-end">@invoice.DueDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="text-end">
                                            @if (daysOverdue > 0)
                                            {
                                                <span class="badge bg-@statusClass">@daysOverdue</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">@Math.Abs(daysOverdue)</span>
                                            }
                                        </td>
                                        <td class="text-end fw-bold">@invoice.InvoiceValue.ToString("N2")</td>
                                        <td class="text-end text-success">@invoice.PaidAmount.ToString("N2")</td>
                                        <td class="text-end text-danger">@invoice.ReturnValue.ToString("N2")</td>
                                        <td class="text-end fw-bold">@invoice.NetAmount.ToString("N2")</td>
                                        <td class="text-end fw-bold text-danger">@invoice.BalanceAmount.ToString("N2")</td>
                                        <td class="text-end">
                                            @if (daysOverdue > 90)
                                            {
                                                <span class="badge bg-danger">Severe (90+ days)</span>
                                            }
                                            else if (daysOverdue > 60)
                                            {
                                                <span class="badge bg-warning">High (61-90 days)</span>
                                            }
                                            else if (daysOverdue > 30)
                                            {
                                                <span class="badge bg-info">Medium (31-60 days)</span>
                                            }
                                            else if (daysOverdue > 0)
                                            {
                                                <span class="badge bg-primary">Low (1-30 days)</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Not Due</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm">
                                                <a href="/Billing/CustomerInvoice?id=@invoice.InvoiceId"
                                                   class="btn btn-outline-primary" title="View Invoice">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <button type="button" class="btn btn-outline-success"
                                                        onclick="recordPayment(@invoice.InvoiceId)" title="Record Payment">
                                                    <i class="fas fa-money-check-alt"></i>
                                                </button>
                                                <a href="/Billing/PrintInvoice?id=@invoice.InvoiceId"
                                                   target="_blank" class="btn btn-outline-secondary" title="Print">
                                                    <i class="fas fa-print"></i>
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <th colspan="5" class="text-end">TOTALS:</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.InvoiceValue).ToString("N2")</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.PaidAmount).ToString("N2")</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.ReturnValue).ToString("N2")</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.NetAmount).ToString("N2")</th>
                                    <th class="text-end text-danger">LKR @Model.OutstandingInvoices.Sum(i => i.BalanceAmount).ToString("N2")</th>
                                    <th colspan="2"></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <small class="text-muted">
                                <i class="fas fa-info-circle me-1"></i>
                                Report generated on @DateTime.Now.ToString("dd-MMM-yyyy hh:mm tt")
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Font Awesome -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Record Payment Function
        function recordPayment(invoiceId) {
            var amount = prompt('Enter payment amount:', '');
            if (amount && !isNaN(amount) && parseFloat(amount) > 0) {
                // Here you would typically make an API call to record the payment
                alert('Payment of LKR ' + amount + ' recorded for invoice ID: ' + invoiceId);
                // Reload the page to update the balance
                setTimeout(function() {
                    window.location.reload();
                }, 1000);
            }
        }   
        }
</script>

<style>
    .card {
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .card-header {
        border-radius: 10px 10px 0 0 !important;
        font-weight: 600;
    }

    .table tbody tr:hover {
        background-color: rgba(255, 193, 7, 0.05);
    }

    .badge {
        padding: 0.35em 0.65em;
        font-size: 0.75em;
        font-weight: 600;
    }

    .btn-group-sm > .btn {
        padding: 0.25rem 0.5rem;
        font-size: 0.875rem;
    }

    .text-success {
        color: #28a745 !important;
    }

    .text-danger {
        color: #dc3545 !important;
    }

    .text-warning {
        color: #ffc107 !important;
    }

    .text-info {
        color: #17a2b8 !important;
    }

    .bg-warning {
        background-color: #ffc107 !important;
    }

        .bg-warning.bg-opacity-25 {
            background-color: rgba(255, 193, 7, 0.25) !important;
        }

    @@media print {
        .no-print

    {
        display: none !important;
    }

    .card {
        box-shadow: none !important;
        border: 1px solid #dee2e6 !important;
    }

    .table {
        font-size: 0.9rem;
    }

    }
</style>
