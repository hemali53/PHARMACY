@page
@model PHARMACY.Pages.Inventory.IndexModel
@{
    ViewData["Title"] = "Inventory Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-4 text-primary">📦 Inventory Management</h1>
            <p class="lead">Manage your pharmacy stock and inventory efficiently</p>
        </div>
    </div>

    <!-- Inventory Summary Cards -->
    <div class="row mt-4">
        <div class="col-md-3 mb-4">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">Total Items</h4>
                            <h2>@Model.TotalItems</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-boxes fa-2x"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">Low Stock</h4>
                            <h2>@Model.LowStockCount</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-exclamation-triangle fa-2x"></i>
                        </div>
                    </div>
                    <a href="/Inventory/LowStock" class="text-white">View Details</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-white bg-danger">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">Expiring Soon</h4>
                            <h2>@Model.ExpiringSoonCount</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-clock fa-2x"></i>
                        </div>
                    </div>
                    <a href="/Inventory/ExpiringSoon" class="text-white">Check Now</a>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="card-title">Out of Stock</h4>
                            <h2>@Model.OutOfStockCount</h2>
                        </div>
                        <div class="align-self-center">
                            <i class="fas fa-times-circle fa-2x"></i>
                        </div>
                    </div>
                    <a href="/Inventory/OutOfStock" class="text-white">Restock</a>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5>Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3 text-center mb-3">
                            <a href="/Medicines" class="btn btn-outline-primary btn-lg p-3">
                                <i class="fas fa-plus-circle fa-2x mb-2"></i><br>
                                Add Stock
                            </a>
                        </div>
                        <div class="col-md-3 text-center mb-3">
                            <a href="/Inventory/StockAdjustment" class="btn btn-outline-warning btn-lg p-3">
                                <i class="fas fa-edit fa-2x mb-2"></i><br>
                                Adjust Stock
                            </a>
                        </div>
                        <div class="col-md-3 text-center mb-3">
                            <a href="/Inventory/StockReport" class="btn btn-outline-info btn-lg p-3">
                                <i class="fas fa-chart-bar fa-2x mb-2"></i><br>
                                Stock Report
                            </a>
                        </div>
                        <div class="col-md-3 text-center mb-3">
                            <a href="/Medicines" class="btn btn-outline-danger btn-lg p-3">
                                <i class="fas fa-pills fa-2x mb-2"></i><br>
                                View Medicines
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Recent Stock Updates</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @foreach (var update in Model.RecentStockUpdates)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@update.MedicineName</strong><br>
                                    <small>Batch: @update.BatchNumber | Qty: @update.Quantity</small>
                                </div>
                                <span class="badge bg-info rounded-pill">@update.UpdateDate.ToString("MMM dd")</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header">
                    <h5>Critical Stock Alerts</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @foreach (var alert in Model.CriticalAlerts)
                        {
                            <div class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@alert.MedicineName</strong><br>
                                    <small>Stock: @alert.CurrentStock units | Min: @alert.MinimumStock</small>
                                </div>
                                <span class="badge bg-danger rounded-pill">@alert.AlertType</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .card {
        transition: transform 0.2s;
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

        .card:hover {
            transform: translateY(-5px);
        }

    .btn {
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn:hover {
            transform: scale(1.05);
        }
</style>