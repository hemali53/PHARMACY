@page
@model PHARMACY.Pages.Medicines.IndexModel
@{
    ViewData["Title"] = "Medicines";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-pills text-primary"></i> Medicines</h2>
    <a asp-page="Create" class="btn btn-primary">
        <i class="fas fa-plus"></i> Add New Medicine
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @foreach (var item in Model.Medicines)
    {
        <div class="col-md-4 mb-4">

            <!-- Debug Info -->
            <div class="small text-muted mb-2">
                MedicineID: @item.MedicineID |
                <a href="/Medicines/BatchList?id=@item.MedicineID" target="_blank">Test Link</a>
            </div>

            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrEmpty(item.ImagePath))
                {
                    <img src="@item.ImagePath" class="card-img-top" alt="@item.Name" style="height: 200px; object-fit: cover;">
                }
                else
                {
                    <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 200px;">
                        <i class="fas fa-pills fa-3x text-secondary"></i>
                    </div>
                }

                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">@item.Name</h5>
                    <p class="card-text flex-grow-1">@item.Description</p>

                    @if (item.ExpiryDate.HasValue)
                    {
                        <p class="card-text">
                            <small class="text-muted">
                                <i class="fas fa-calendar-alt"></i> Expires: @item.ExpiryDate.Value.ToString("yyyy-MM-dd")
                            </small>
                        </p>
                    }

                    <div class="btn-group btn-group-sm mt-auto">
                        <a asp-page="./Edit" asp-route-id="@item.MedicineID" class="btn btn-outline-primary">Edit</a>
                        <a href="/Medicines/BatchList?id=@item.MedicineID" class="btn btn-outline-info">Batches</a>
                       <a asp-page="./Delete" asp-route-id="@item.MedicineID" class="btn btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Medicines.Any())
{
    <div class="text-center py-5">
        <i class="fas fa-pills fa-4x text-muted mb-3"></i>
        <h4 class="text-muted">No Medicines Found</h4>
        <p class="text-muted">Get started by adding your first medicine.</p>
        <a asp-page="Create" class="btn btn-primary">Add First Medicine</a>
    </div>
}


