@page
@model IndexModel
@{
    ViewData["Title"] = "Pharmacy Dashboard";
    Layout = "_Layout";
}

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h1 class="display-5 text-primary mb-1">🏥 Pharmacy Management System</h1>
                    <p class="lead mb-0">Comprehensive Dashboard - @DateTime.Now.ToString("MMMM dd, yyyy")</p>
                </div>
                <div class="text-end">
                    <button class="btn btn-outline-primary" onclick="window.print()">
                        <i class="fas fa-print me-2"></i>Print Report
                    </button>
                </div>
            </div>
        </div>
    </div>
    </div>
    <!-- Simple Sales Report -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-primary">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-simple me-2"></i>Sales Report</h5>
                    <small class="opacity-75">Key metrics at a glance</small>
                </div>
                <div class="card-body">
                    <div class="row">
                        <!-- Today's Sales -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-success">
                                <div class="card-body text-center">
                                    <div class="mb-3">
                                        <i class="fas fa-sun fa-3x text-warning"></i>
                                    </div>
                                    <h6 class="text-muted mb-2">Today's Sales</h6>
                                    <h3 class="fw-bold text-success">LKR @Model.TodaysSales.ToString("N0")</h3>
                                    <small class="text-muted">@DateTime.Now.ToString("dd MMM yyyy")</small>
                                </div>
                            </div>
                        </div>

                        <!-- Net Sales -->
                        <div class="col-md-4 mb-3">
                            <div class="card h-100 border-primary">
                                <div class="card-body text-center">
                                    <div class="mb-3">
                                        <i class="fas fa-calculator fa-3x text-primary"></i>
                                    </div>
                                    <h6 class="text-muted mb-2">Monthly Sales</h6>
                                    <h3 class="fw-bold text-primary">LKR @Model.NetSales.ToString("N0")</h3>
                                    <small class="text-muted">Sales - Returns</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Returns Summary -->
                    <div class="row mt-3">
                        <div class="col-md-6 mb-3">
                            <div class="card h-100 border-warning">
                                <div class="card-body text-center">
                                    <h6 class="text-muted mb-2">Today's Returns</h6>
                                    <h3 class="fw-bold text-warning">LKR @Model.TodaysReturns.ToString("N0")</h3>
                                    <small class="text-muted">Refunds & Returns</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="card h-100 border-secondary">
                                <div class="card-body text-center">
                                    <h6 class="text-muted mb-2">Monthly Returns</h6>
                                    <h3 class="fw-bold text-secondary">LKR @Model.TotalReturns.ToString("N0")</h3>
                                    <small class="text-muted">Total returns this month</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Cards -->
    <div class="row mb-4">
        <div class="col-xl-3 col-lg-6 mb-4">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Total Medicines</h6>
                            <h2 class="fw-bold">@Model.TotalMedicines</h2>
                        </div>
                        <i class="fas fa-pills fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="text-white small stretched-link" href="/Medicines">View Details</a>
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 mb-4">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Total Customers</h6>
                            <h2 class="fw-bold">@Model.TotalCustomers</h2>
                        </div>
                        <i class="fas fa-users fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="text-white small stretched-link" href="/Customer/Register">Register New</a>
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 mb-4">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Today's Sales</h6>
                            <h2 class="fw-bold">LKR @Model.TodaysSales.ToString("N0")</h2>
                        </div>
                        <i class="fas fa-shopping-cart fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="text-white small stretched-link" href="/Billing/CustomerInvoice">Create Bill</a>
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
        </div>

        <div class="col-xl-3 col-lg-6 mb-4">
            <div class="card bg-warning text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="text-white-50">Monthly Sales</h6>
                            <h2 class="fw-bold">LKR @Model.TotalSale.ToString("N0")</h2>
                        </div>
                        <i class="fas fa-chart-line fa-3x opacity-50"></i>
                    </div>
                </div>
                <div class="card-footer d-flex align-items-center justify-content-between">
                    <a class="text-white small stretched-link" href="#monthlyChart">View Report</a>
                    <i class="fas fa-chevron-right"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales vs Purchase Chart -->
    <div class="row mb-4">
        <div class="col-md-6 mb-4">
            <div class="card h-150">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-balance-scale me-2"></i>Sales vs Purchase (Last 6 Months)</h5>
                    <small class="opacity-75">Comparison of Sales and Purchase amounts</small>
                </div>
                <div class="card-body">
                    <canvas id="salesVsPurchaseChart" height="900"></canvas>
                </div>
                <div class="card-footer">
                    <div class="row text-center">
                        <div class="col-6">
                            <small class="text-muted d-block">Total Purchase</small>
                            <strong class="text-danger">LKR @Model.SalesVsPurchaseData.Sum(s => s.Purchase).ToString("N0")</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Total Sales</small>
                            <strong class="text-success">LKR @Model.SalesVsPurchaseData.Sum(s => s.Sales).ToString("N0")</strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Top 5 Selling Medicines Chart -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Top 5 Selling Medicines</h5>
                    <small class="opacity-75">Current Month: @DateTime.Now.ToString("MMMM yyyy")</small>
                </div>
                <div class="card-body">
                    <canvas id="topMedicinesChart" height="250"></canvas>
                </div>
                <div class="card-footer">
                    <div class="table-responsive">
                        <table class="table table-sm table-borderless mb-0">
                            <thead>
                                <tr>
                                    <th>Medicine</th>
                                    <th class="text-end">Quantity</th>
                                    <th class="text-end">Sales (LKR)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var medicine in Model.TopSellingMedicines)
                                {
                                    <tr>
                                        <td>@medicine.MedicineName</td>
                                        <td class="text-end">@medicine.QuantitySold.ToString("N0")</td>
                                        <td class="text-end">@medicine.TotalSales.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Daily Progress Chart - Now full width since Income Expense Statement removed -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card h-100">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-bar me-2"></i>Daily Sales Progress</h5>
                    <small class="opacity-75">Last 7 Days</small>
                </div>
                <div class="card-body">
                    <canvas id="dailyProgressChart" height="300"></canvas>
                </div>
                <div class="card-footer">
                    <div class="row text-center">
                        <div class="col-3">
                            <small class="text-muted d-block">Today</small>
                            <strong>LKR @Model.TodaysSales.ToString("N0")</strong>
                        </div>
                        <div class="col-3">
                            <small class="text-muted d-block">Yesterday</small>
                            @{
                                var yesterdaySales = Model.DailySales.Count >= 2 ? Model.DailySales[^2].TotalSales : 0;
                            }
                            <strong>LKR @yesterdaySales.ToString("N0")</strong>
                        </div>
                        <div class="col-3">
                            <small class="text-muted d-block">7-Day Avg</small>
                            <strong>LKR @(Model.DailySales.Count > 0 ? Model.DailySales.Average(d => d.TotalSales).ToString("N0") : "0")</strong>
                        </div>
                        <div class="col-3">
                            <small class="text-muted d-block">Change</small>
                            @{
                                var changePercent = yesterdaySales > 0 ?
                                ((Model.TodaysSales - yesterdaySales) / yesterdaySales * 100) : 0;
                                var changeClass = changePercent >= 0 ? "text-success" : "text-danger";
                                var changeIcon = changePercent >= 0 ? "fa-arrow-up" : "fa-arrow-down";
                            }
                            <strong class="@changeClass">
                                <i class="fas @changeIcon me-1"></i>
                                @Math.Abs(changePercent).ToString("N1")%
                            </strong>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Return Customers and Products Section -->
    <div class="row mb-4">
        <!-- Top 10 Return Customers -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-danger text-white">
                    <h5 class="mb-0"><i class="fas fa-user-times me-2"></i>Top 10 Return Customers</h5>
                    <small class="opacity-75">Last 30 Days - Highest Return Values</small>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Customer Name</th>
                                    <th class="text-end">Returns</th>
                                    <th class="text-end">Value (LKR)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int customerRank = 1;
                                    decimal totalCustomerReturns = Model.TopReturnCustomers.Sum(c => c.TotalReturnValue);
                                }
                                @foreach (var customer in Model.TopReturnCustomers)
                                {
                                    var percentage = totalCustomerReturns > 0 ? (customer.TotalReturnValue / totalCustomerReturns * 100) : 0;
                                    <tr>
                                        <td class="fw-bold">@customerRank</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-danger bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2">
                                                    <i class="fas fa-user text-danger"></i>
                                                </div>
                                                <span>@customer.CustomerName</span>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <span class="badge bg-danger bg-opacity-10 text-danger">@customer.ReturnCount</span>
                                        </td>
                                        <td class="text-end fw-bold">
                                            @customer.TotalReturnValue.ToString("N2")
                                        </td>
                                    </tr>
                                    customerRank++;
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <th colspan="3" class="text-end">Total:</th>
                                    <th class="text-end">LKR @totalCustomerReturns.ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Based on return values in last 30 days
                        </small>
                        <a href="/PRN" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-external-link-alt me-1"></i>View All
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Return Products List -->
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-undo-alt me-2"></i>Return Products List</h5>
                    <small class="opacity-75">Last 30 Days - Frequently Returned Items</small>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-light">
                                <tr>
                                    <th>#</th>
                                    <th>Product Name</th>
                                    <th class="text-end">Qty</th>
                                    <th class="text-end">Value (LKR)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int productRank = 1;
                                    decimal totalProductReturns = Model.ReturnProducts.Sum(p => p.ReturnValue);
                                }
                                @foreach (var product in Model.ReturnProducts)
                                {
                                    var percentage = totalProductReturns > 0 ? (product.ReturnValue / totalProductReturns * 100) : 0;
                                    <tr>
                                        <td class="fw-bold">@productRank</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2">
                                                    <i class="fas fa-pills text-warning"></i>
                                                </div>
                                                <div>
                                                    <div>@product.ProductName</div>
                                                    <small class="text-muted">Returns: @product.ReturnCount</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <span class="badge bg-warning bg-opacity-10 text-dark">@product.ReturnQuantity</span>
                                        </td>
                                        <td class="text-end fw-bold">
                                            @product.ReturnValue.ToString("N2")
                                        </td>
                                    </tr>
                                    productRank++;
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <th colspan="3" class="text-end">Total:</th>
                                    <th class="text-end">LKR @totalProductReturns.ToString("N2")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Total returned items in last 30 days
                        </small>
                        <a href="/PRN" class="btn btn-sm btn-outline-warning">
                            <i class="fas fa-external-link-alt me-1"></i>Manage Returns
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Monthly Sales Chart -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-line me-2"></i>Monthly Sales Report (Last 6 Months)</h5>
                </div>
                <div class="card-body">
                    <canvas id="monthlySalesChart" height="100"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Outstanding Invoice Report Section -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-warning text-dark">
                    <h5 class="mb-0"><i class="fas fa-file-invoice-dollar me-2"></i>Outstanding Invoices Report</h5>
                    <small class="text-dark">Pending payments from customers</small>
                </div>
                <div class="card-body">
                    <!-- Summary Cards -->
                    <div class="row mb-4">
                        <div class="col-md-3 col-sm-6 mb-3">
                            <div class="card border-warning">
                                <div class="card-body text-center">
                                    <h6 class="text-muted mb-2">Total Outstanding</h6>
                                    <h3 class="text-warning fw-bold">LKR @Model.TotalOutstanding.ToString("N2")</h3>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-3 col-sm-6 mb-3">
                            <div class="card border-info">
                                <div class="card-body text-center">
                                    <h6 class="text-muted mb-2">Open Invoices</h6>
                                    <h3 class="text-info fw-bold">@Model.OpenInvoiceCount</h3>
                                </div>
                            </div>
                        </div>

                    <!-- Outstanding Invoices Table -->
                    <div class="table-responsive">
                        <table class="table table-hover table-sm">
                            <thead class="table-warning">
                                <tr>
                                    <th>#</th>
                                    <th>Customer</th>
                                    <th class="text-end">Invoice No</th>
                                    <th class="text-end">Invoice Date</th>
                                    <th class="text-end">Due Date</th>
                                    <th class="text-end">Days Overdue</th>
                                    <th class="text-end">Invoice Value</th>
                                    <th class="text-end">Paid Amount</th>
                                    <th class="text-end">Return Value</th>
                                    <th class="text-end">Balance</th>
                                    @* <th class="text-end">Status</th> *@
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int outstandingRank = 1;
                                }
                                @foreach (var invoice in Model.OutstandingInvoices)
                                {
                                    var daysOverdue = (DateTime.Today - invoice.DueDate).Days;
                                    var statusClass = daysOverdue > 30 ? "danger" :
                                    daysOverdue > 15 ? "warning" : "info";

                                    <tr>
                                        <td class="fw-bold">@outstandingRank</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="avatar-sm bg-warning bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-2">
                                                    <i class="fas fa-user text-warning"></i>
                                                </div>
                                                <div>
                                                    <div>@invoice.CustomerName</div>
                                                    <small class="text-muted">@invoice.CustomerPhone</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <span class="badge bg-dark">@invoice.InvoiceNumber</span>
                                        </td>
                                        <td class="text-end">@invoice.InvoiceDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="text-end">@invoice.DueDate.ToString("dd-MMM-yyyy")</td>
                                        <td class="text-end">
                                            @if (daysOverdue > 0)
                                            {
                                                <span class="badge bg-@statusClass">@daysOverdue Days</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">On Time</span>
                                            }
                                        </td>
                                        <td class="text-end fw-bold">@invoice.InvoiceValue.ToString("N2")</td>
                                        <td class="text-end">@invoice.PaidAmount.ToString("N2")</td>
                                        <td class="text-end">@invoice.ReturnValue.ToString("N2")</td>
                                        <td class="text-end fw-bold text-danger">@invoice.BalanceAmount.ToString("N2")</td>
                                        @* <td class="text-end">
                                            @if (daysOverdue > 30)
                                            {
                                                <span class="badge bg-danger">Severe Overdue</span>
                                            }
                                            else if (daysOverdue > 15)
                                            {
                                                <span class="badge bg-warning">Overdue</span>
                                            }
                                            else if (daysOverdue > 0)
                                            {
                                                <span class="badge bg-info">Due Soon</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Active</span>
                                            }
                                        </td> *@
                                    </tr>
                                    outstandingRank++;
                                }
                            </tbody>
                            <tfoot class="table-secondary">
                                <tr>
                                    <th colspan="6" class="text-end">Totals:</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.InvoiceValue).ToString("N2")</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.PaidAmount).ToString("N2")</th>
                                    <th class="text-end">LKR @Model.OutstandingInvoices.Sum(i => i.ReturnValue).ToString("N2")</th>
                                    <th class="text-end text-danger">LKR @Model.OutstandingInvoices.Sum(i => i.BalanceAmount).ToString("N2")</th>
                                    <th></th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Showing @Model.OutstandingInvoices.Count outstanding invoices
                        </small>
                        <a href="/OutStandingReport" class="btn btn-sm btn-warning">
                            <i class="fas fa-external-link-alt me-1"></i>View Full Report
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Net Sales Breakdown Section -->
    <div class="row mt-4">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0"><i class="fas fa-chart-pie me-2"></i>Net Sales Breakdown - @DateTime.Now.ToString("MMMM yyyy")</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-success bg-opacity-10">
                                <h6 class="text-success">Total Sales</h6>
                                <h3 class="fw-bold">LKR @Model.TotalSale.ToString("N0")</h3>
                                <small class="text-muted">Gross Sales Amount</small>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-danger bg-opacity-10">
                                <h6 class="text-danger">Total Returns</h6>
                                <h3 class="fw-bold">LKR @Model.TotalReturns.ToString("N0")</h3>
                                <small class="text-muted">Returns & Refunds</small>
                            </div>
                        </div>
                        <div class="col-md-4 mb-3">
                            <div class="p-3 border rounded bg-primary bg-opacity-10">
                                <h6 class="text-primary">Net Sales</h6>
                                <h3 class="fw-bold">LKR @Model.NetSales.ToString("N0")</h3>
                                <small class="text-muted">Actual Revenue</small>
                            </div>
                        </div>
                    </div>
                    <div class="mt-4">
                        <div class="progress" style="height: 30px;">
                            <div class="progress-bar bg-success"
                                 style="width: @(Model.TotalSale > 0 ? (Model.TotalSale / (Model.TotalSale + Model.TotalReturns) * 100).ToString("0") : "0")%">
                                <span class="fw-bold">Sales: @(Model.TotalSale > 0 ? (Model.TotalSale / (Model.TotalSale + Model.TotalReturns) * 100).ToString("0") : "0")%</span>
                            </div>
                            <div class="progress-bar bg-danger"
                                 style="width: @(Model.TotalReturns > 0 ? (Model.TotalReturns / (Model.TotalSale + Model.TotalReturns) * 100).ToString("0") : "0")%">
                                <span class="fw-bold">Returns: @(Model.TotalReturns > 0 ? (Model.TotalReturns / (Model.TotalSale + Model.TotalReturns) * 100).ToString("0") : "0")%</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

