<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Monthly Sales Chart
        var monthlyCtx = document.getElementById('monthlySalesChart').getContext('2d');
        var monthlyMonths = @Html.Raw(Json.Serialize(Model.MonthlySales.Select(m => m.MonthName).ToArray()));
        var monthlySales = @Html.Raw(Json.Serialize(Model.MonthlySales.Select(m => m.TotalSales).ToArray()));

        var monthlyChart = new Chart(monthlyCtx, {
            type: 'line',
            data: {
                labels: monthlyMonths,
                datasets: [{
                    label: 'Sales (LKR)',
                    data: monthlySales,
                    backgroundColor: 'rgba(54, 162, 235, 0.2)',
                    borderColor: 'rgba(54, 162, 235, 1)',
                    borderWidth: 2,
                    fill: true,
                    tension: 0.4
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'Sales: LKR ' + context.parsed.y.toLocaleString('en-US', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'LKR ' + value.toLocaleString('en-US', {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                });
                            }
                        }
                    }
                }
            }
        });

        // Daily Progress Chart
        var dailyCtx = document.getElementById('dailyProgressChart').getContext('2d');
        var dailyDates = @Html.Raw(Json.Serialize(Model.DailySales.Select(d => d.DisplayDate).ToArray()));
        var dailySales = @Html.Raw(Json.Serialize(Model.DailySales.Select(d => d.TotalSales).ToArray()));

        var dailyChart = new Chart(dailyCtx, {
            type: 'bar',
            data: {
                labels: dailyDates,
                datasets: [{
                    label: 'Daily Sales',
                    data: dailySales,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.7)',
                        'rgba(54, 162, 235, 0.7)',
                        'rgba(255, 206, 86, 0.7)',
                        'rgba(75, 192, 192, 0.7)',
                        'rgba(153, 102, 255, 0.7)',
                        'rgba(255, 159, 64, 0.7)',
                        'rgba(40, 167, 69, 0.7)'
                    ],
                    borderColor: [
                        'rgba(255, 99, 132, 1)',
                        'rgba(54, 162, 235, 1)',
                        'rgba(255, 206, 86, 1)',
                        'rgba(75, 192, 192, 1)',
                        'rgba(153, 102, 255, 1)',
                        'rgba(255, 159, 64, 1)',
                        'rgba(40, 167, 69, 1)'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: false
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return 'Sales: LKR ' + context.parsed.y.toLocaleString('en-US', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'LKR ' + value.toLocaleString('en-US', {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                });
                            }
                        }
                    }
                }
            }
        });

        // Sales vs Purchase Chart
        var salesVsPurchaseCtx = document.getElementById('salesVsPurchaseChart').getContext('2d');
        var salesVsPurchaseMonths = @Html.Raw(Json.Serialize(Model.SalesVsPurchaseData.Select(s => s.MonthName).ToArray()));
        var salesData = @Html.Raw(Json.Serialize(Model.SalesVsPurchaseData.Select(s => s.Sales).ToArray()));
        var purchaseData = @Html.Raw(Json.Serialize(Model.SalesVsPurchaseData.Select(s => s.Purchase).ToArray()));

        var salesVsPurchaseChart = new Chart(salesVsPurchaseCtx, {
            type: 'bar',
            data: {
                labels: salesVsPurchaseMonths,
                datasets: [
                    {
                        label: 'Sales',
                        data: salesData,
                        backgroundColor: 'rgba(40, 167, 69, 0.7)',
                        borderColor: 'rgba(40, 167, 69, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Purchase',
                        data: purchaseData,
                        backgroundColor: 'rgba(220, 53, 69, 0.7)',
                        borderColor: 'rgba(220, 53, 69, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': LKR ' + context.parsed.y.toLocaleString('en-US', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                });
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return 'LKR ' + value.toLocaleString('en-US', {
                                    minimumFractionDigits: 0,
                                    maximumFractionDigits: 0
                                });
                            }
                        }
                    }
                }
            }
        });

        // Top 5 Selling Medicines Chart
        var topMedicinesCtx = document.getElementById('topMedicinesChart').getContext('2d');
        var medicineNames = @Html.Raw(Json.Serialize(Model.TopSellingMedicines.Select(m => m.MedicineName).ToArray()));
        var medicineQuantities = @Html.Raw(Json.Serialize(Model.TopSellingMedicines.Select(m => m.QuantitySold).ToArray()));
        var medicineSales = @Html.Raw(Json.Serialize(Model.TopSellingMedicines.Select(m => m.TotalSales).ToArray()));

        var topMedicinesChart = new Chart(topMedicinesCtx, {
            type: 'doughnut',
            data: {
                labels: medicineNames,
                datasets: [{
                    data: medicineQuantities,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.8)',
                        'rgba(54, 162, 235, 0.8)',
                        'rgba(255, 206, 86, 0.8)',
                        'rgba(75, 192, 192, 0.8)',
                        'rgba(153, 102, 255, 0.8)'
                    ],
                    borderColor: [
                        'rgba(255, 99, 132, 1)',
                        'rgba(54, 162, 235, 1)',
                        'rgba(255, 206, 86, 1)',
                        'rgba(75, 192, 192, 1)',
                        'rgba(153, 102, 255, 1)'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'right',
                        labels: {
                            boxWidth: 12,
                            padding: 15
                        }
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                var label = context.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                label += context.parsed + ' units';
                                label += ' (LKR ' + medicineSales[context.dataIndex].toLocaleString('en-US', {
                                    minimumFractionDigits: 2,
                                    maximumFractionDigits: 2
                                }) + ')';
                                return label;
                            }
                        }
                    }
                }
            }
        });
    });

    // Auto-refresh every 5 minutes
    setTimeout(function() {
        window.location.reload();
    }, 5 * 60 * 1000);
</script>

