        }

        // Batch filter functionality
        document.getElementById('batchFilter').addEventListener('input', function() {
            const filterTerm = this.value.toLowerCase().trim();

            if (filterTerm === '') {
                filteredBatches = [...allBatches];
                renderBatchTable(filteredBatches);
                return;
            }

            filteredBatches = allBatches.filter(batch =>
                batch.batchNumber.toLowerCase().includes(filterTerm)
            );

            renderBatchTable(filteredBatches);
        });

        function clearBatchFilter() {
            document.getElementById('batchFilter').value = '';
            filteredBatches = [...allBatches];
            renderBatchTable(filteredBatches);
        }

        function renderTable() {
            let body = document.querySelector("#itemTable tbody");
            body.innerHTML = "";

            let grandTotal = 0;

            items.forEach((item, index) => {
                grandTotal += item.SubTotal;
                body.innerHTML += `
                    <tr>
                        <td>${item.MedicineName}</td>
                        <td>${item.BatchNumber}</td>
                        <td>
                            <input type="number" class="form-control form-control-sm"
                                   value="${item.Qty}" min="1"
                                   onchange="updateQuantity(${index}, parseInt(this.value))"
                                   style="width: 80px;">
                        </td>
                        <td>${item.CostPrice.toFixed(2)}</td>
                        <td>${item.SubTotal.toFixed(2)}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger" onclick="removeItem(${index})">X</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById("totalAmount").textContent = grandTotal.toFixed(2);
            document.getElementById("itemsJson").value = JSON.stringify(items);
        }

        function removeItem(i) {
            if (confirm('Are you sure you want to remove this item?')) {
                items.splice(i, 1);
                renderTable();
            }
        }

        // Close suggestions when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#medicineSearch') && !e.target.closest('#medicineSuggestions')) {
                document.getElementById('medicineSuggestions').style.display = 'none';
            }
        });
    </script>
}