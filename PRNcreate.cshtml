@* @page
@model PHARMACY.Pages.PRNcreateModel
@{
    ViewData["Title"] = "Purchase Return Note (PRN)";
}

<h2 class="text-center mb-4">Purchase Return Note (PRN)</h2>

<!-- Success Message Alert -->
@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @Model.SuccessMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container">
    <form method="post">
        <div class="row mb-3">
            <div class="col-md-4">
                <label class="form-label">Return No</label>
                <input asp-for="PRN.ReturnNo" class="form-control" readonly />
                <small class="text-muted">Auto-generated</small>
            </div>
            <div class="col-md-4">
                <label class="form-label">Date</label>
                <input asp-for="PRN.ReturnDate" type="date" class="form-control" readonly />
            </div>
            <div class="col-md-4">
                <label class="form-label">Supplier</label>
                <select asp-for="PRN.SupplierId" asp-items="Model.SupplierList" class="form-select" required>
                    <option value="">-- Select Supplier --</option>
                </select>
                <span asp-validation-for="PRN.SupplierId" class="text-danger"></span>
            </div>
        </div>
        <hr />

        <h5>Add Items to Return</h5>

        <div class="row mb-3">
            <div class="col-md-12">
                <label class="form-label">Search Medicine</label>
                <input type="text" id="medicineSearch" class="form-control" placeholder="Type medicine name..." />
                <div id="medicineSuggestions" class="list-group" style="display: none; position: absolute; z-index: 1000; width: 100%;"></div>
            </div>
        </div>

        <!-- Batch Selection Section -->
        <div id="batchSection" style="display: none;">
            <div class="card mb-3">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h6 class="mb-0">Available Batches for <span id="selectedMedicineName"></span></h6>
                    <div class="d-flex gap-2">
                        <input type="text" id="batchFilter" class="form-control form-control-sm" placeholder="Filter batches..." style="width: 200px;" />
                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="clearBatchFilter()">Clear</button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="alert alert-info py-2 mb-3">
                        <small><i class="bi bi-info-circle"></i> Batches are sorted by expiry date (earliest expiry first)</small>
                    </div>
                    <table class="table table-sm table-bordered" id="batchTable">
                        <thead class="table-light">
                            <tr>
                                <th>Batch Number</th>
                                <th>Manufacture Date</th>
                                <th>Expiry Date</th>
                                <th>Days to Expiry</th>
                                <th>Available Stock</th>
                            </tr>
                        </thead>
                        <tbody id="batchTableBody"></tbody>
                    </table>
                    <div class="mt-3">
                        <label class="form-label">Return Quantity for Filtered Batches</label>
                        <div class="input-group" style="width: 200px;">
                            <input type="number" class="form-control" id="globalReturnQty" min="1" value="1">
                            <button type="button" class="btn btn-warning" onclick="addFilteredBatches()">Add Filtered Batches</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Selected Items Table -->
        <div class="table-responsive">
            <table class="table table-bordered" id="itemTable">
                <thead class="table-light">
                    <tr>
                        <th>Medicine</th>
                        <th>Batch Number</th>
                        <th>Qty</th>
                        <th>Cost Price</th>
                        <th>Sub Total</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody></tbody>
                <tfoot>
                    <tr class="table-info">
                        <td colspan="4" class="text-end"><strong>Total Amount:</strong></td>
                        <td><strong id="totalAmount">0.00</strong></td>
                        <td></td>
                    </tr>
                </tfoot>
            </table>
        </div>

        <input type="hidden" asp-for="ItemsJson" id="itemsJson" />

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger">Save PRN</button>
            <a href="/PRNcreate" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <script>
        let items = [];
        let currentMedicineId = null;
        let currentMedicineName = null;
        let allBatches = []; // Store all batches for filtering
        let filteredBatches = []; // Store currently filtered batches

        // Auto set today's date when page loads
        document.addEventListener('DOMContentLoaded', function() {
            const today = new Date().toISOString().split('T')[0];
            document.getElementById('PRN_ReturnDate').value = today;

            // Clear any existing items when page loads
            items = [];
            renderTable();
        });

        // Medicine Search with Suggestions
        document.getElementById('medicineSearch').addEventListener('input', function() {
            const searchTerm = this.value.trim();

            if (searchTerm.length < 2) {
                document.getElementById('medicineSuggestions').style.display = 'none';
                return;
            }

            fetch(`/PRNcreate?handler=SearchMedicines&searchTerm=${encodeURIComponent(searchTerm)}`)
                .then(response => response.json())
                .then(data => {
                    const suggestionsContainer = document.getElementById('medicineSuggestions');
                    suggestionsContainer.innerHTML = '';

                    if (data.length > 0) {
                        data.forEach(medicine => {
                            const suggestionItem = document.createElement('button');
                            suggestionItem.type = 'button';
                            suggestionItem.className = 'list-group-item list-group-item-action';
                            suggestionItem.textContent = `${medicine.name} (${medicine.description})`;
                            suggestionItem.onclick = () => selectMedicine(medicine);
                            suggestionsContainer.appendChild(suggestionItem);
                        });
                        suggestionsContainer.style.display = 'block';
                    } else {
                        suggestionsContainer.style.display = 'none';
                    }
                })
                .catch(error => console.error('Error:', error));
        });

        function selectMedicine(medicine) {
            currentMedicineId = medicine.medicineID;
            currentMedicineName = medicine.name;

            document.getElementById('medicineSearch').value = medicine.name;
            document.getElementById('medicineSuggestions').style.display = 'none';
            document.getElementById('selectedMedicineName').textContent = medicine.name;

            // Load batches for selected medicine
            loadBatches(medicine.medicineID);
        }

        function loadBatches(medicineId) {
            fetch(`/PRNcreate?handler=GetBatches&medicineId=${medicineId}`)
                .then(response => response.json())
                .then(data => {
                    allBatches = data; // Store all batches for filtering
                    filteredBatches = [...allBatches]; // Initialize filtered batches with all batches
                    renderBatchTable(filteredBatches);

                    if (data.length > 0) {
                        document.getElementById('batchSection').style.display = 'block';
                    } else {
                        document.getElementById('batchTableBody').innerHTML = '<tr><td colspan="5" class="text-center">No batches available</td></tr>';
                        document.getElementById('batchSection').style.display = 'block';
                    }
                })
                .catch(error => console.error('Error:', error));
        }

        function renderBatchTable(batches) {
            const batchTableBody = document.getElementById('batchTableBody');
            batchTableBody.innerHTML = '';

            if (batches.length > 0) {
                batches.forEach(batch => {
                    const daysToExpiry = batch.daysToExpiry;
                    let expiryClass = '';

                    // Color coding based on days to expiry
                    if (daysToExpiry < 0) {
                        expiryClass = 'table-danger'; // Expired
                    } else if (daysToExpiry <= 30) {
                        expiryClass = 'table-warning'; // Expiring within 30 days
                    } else if (daysToExpiry <= 90) {
                        expiryClass = 'table-info'; // Expiring within 90 days
                    }

                    const row = document.createElement('tr');
                    row.className = expiryClass;
                    row.innerHTML = `
                        <td>${batch.batchNumber}</td>
                        <td>${batch.manufactureDate ? new Date(batch.manufactureDate).toLocaleDateString() : 'N/A'}</td>
                        <td>${batch.expiryDate ? new Date(batch.expiryDate).toLocaleDateString() : 'N/A'}</td>
                        <td>
                            <span class="badge ${getExpiryBadgeClass(daysToExpiry)}">
                                ${formatDaysToExpiry(daysToExpiry)}
                            </span>
                        </td>
                        <td>${batch.quantity}</td>
                    `;
                    batchTableBody.appendChild(row);
                });
            } else {
                batchTableBody.innerHTML = '<tr><td colspan="5" class="text-center">No batches available</td></tr>';
            }
        }

        function getExpiryBadgeClass(daysToExpiry) {
            if (daysToExpiry < 0) return 'bg-danger'; // Expired
            if (daysToExpiry <= 30) return 'bg-warning'; // Expiring soon
            if (daysToExpiry <= 90) return 'bg-info'; // Expiring in 3 months
            return 'bg-success'; // More than 90 days
        }

        function formatDaysToExpiry(daysToExpiry) {
            if (daysToExpiry < 0) {
                return `Expired ${Math.abs(daysToExpiry)} days ago`;
            } else if (daysToExpiry === 0) {
                return 'Expires today';
            } else if (daysToExpiry === 1) {
                return '1 day left';
            } else {
                return `${daysToExpiry} days left`;
            }
        }

        // Add filtered batches with global quantity
        function addFilteredBatches() {
            const globalQtyInput = document.getElementById('globalReturnQty');
            const returnQty = parseInt(globalQtyInput.value);

            if (returnQty <= 0) {
                alert('Please enter a valid quantity greater than 0.');
                return;
            }

            let addedCount = 0;

            filteredBatches.forEach(batch => {
                if (returnQty <= batch.quantity) {
                    // Check if batch already exists in items
                    const existingIndex = items.findIndex(item => item.BatchId === batch.batchID);

                    if (existingIndex > -1) {
                        // Update existing item quantity
                        items[existingIndex].Qty = returnQty;
                        items[existingIndex].SubTotal = items[existingIndex].Qty * items[existingIndex].CostPrice;
                    } else {
                        // Add new item
                        const subTotal = returnQty * batch.purchasePrice;

                        items.push({
                            MedicineId: currentMedicineId,
                            MedicineName: currentMedicineName,
                            BatchId: batch.batchID,
                            BatchNumber: batch.batchNumber,
                            Qty: returnQty,
                            CostPrice: batch.purchasePrice,
                            SubTotal: subTotal
                        });
                    }
                    addedCount++;
                } else {
                    alert(`Invalid quantity for batch ${batch.batchNumber}. Available: ${batch.quantity}, Requested: ${returnQty}`);
                }
            });

            if (addedCount > 0) {
                renderTable();
                alert(`Successfully added ${addedCount} batch(es) with quantity ${returnQty}!`);

                // Reset selection
                document.getElementById('batchSection').style.display = 'none';
                document.getElementById('medicineSearch').value = '';
                currentMedicineId = null;
                currentMedicineName = null;
            } else {
                alert('No batches were added. Please check the quantity.');
            }
        }

        // Update quantity in selected items table
        function updateQuantity(index, newQty) {
            const item = items[index];
            const batch = allBatches.find(b => b.batchID === item.BatchId);

            if (batch && newQty > 0 && newQty <= batch.quantity) {
                item.Qty = newQty;
                item.SubTotal = item.Qty * item.CostPrice;
                renderTable();
            } else {
                alert(`Invalid quantity for batch ${item.BatchNumber}. Available: ${batch.quantity}`);
                // Reset to previous value
                renderTable();
            }
        }

        // Batch filter functionality
        document.getElementById('batchFilter').addEventListener('input', function() {
            const filterTerm = this.value.toLowerCase().trim();

            if (filterTerm === '') {
                filteredBatches = [...allBatches];
                renderBatchTable(filteredBatches);
                return;
            }

            filteredBatches = allBatches.filter(batch =>
                batch.batchNumber.toLowerCase().includes(filterTerm)
            );

            renderBatchTable(filteredBatches);
        });

        function clearBatchFilter() {
            document.getElementById('batchFilter').value = '';
            filteredBatches = [...allBatches];
            renderBatchTable(filteredBatches);
        }

        function renderTable() {
            let body = document.querySelector("#itemTable tbody");
            body.innerHTML = "";

            let grandTotal = 0;

            items.forEach((item, index) => {
                grandTotal += item.SubTotal;
                body.innerHTML += `
                    <tr>
                        <td>${item.MedicineName}</td>
                        <td>${item.BatchNumber}</td>
                        <td>
                            <input type="number" class="form-control form-control-sm"
                                   value="${item.Qty}" min="1"
                                   onchange="updateQuantity(${index}, parseInt(this.value))"
                                   style="width: 80px;">
                        </td>
                        <td>${item.CostPrice.toFixed(2)}</td>
                        <td>${item.SubTotal.toFixed(2)}</td>
                        <td>
                            <button type="button" class="btn btn-sm btn-danger" onclick="removeItem(${index})">X</button>
                        </td>
                    </tr>
                `;
            });

            document.getElementById("totalAmount").textContent = grandTotal.toFixed(2);
            document.getElementById("itemsJson").value = JSON.stringify(items);
        }

        function removeItem(i) {
            if (confirm('Are you sure you want to remove this item?')) {
                items.splice(i, 1);
                renderTable();
            }
        }

        // Close suggestions when clicking outside
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#medicineSearch') && !e.target.closest('#medicineSuggestions')) {
                document.getElementById('medicineSuggestions').style.display = 'none';
            }
        });
    </script>
} *@




