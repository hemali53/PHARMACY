@page
@model PHARMACY.Pages.Medicines.CreateModel
@{
    ViewData["Title"] = "Add New Medicine";
}

<div class="row">
    <div class="col-md-8 offset-md-2">
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h3 class="card-title mb-0">
                    <i class="fas fa-plus-circle"></i> Add New Medicine
                </h3>
            </div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label asp-for="Medicine.Name" class="form-label fw-bold"></label>
                                <input asp-for="Medicine.Name" class="form-control" placeholder="Enter medicine name" />
                                <span asp-validation-for="Medicine.Name" class="text-danger small"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Medicine.AverageCost" class="form-label fw-bold"></label>
                                <div class="input-group">
                                    <span class="input-group-text">LKR</span>
                                    <input asp-for="Medicine.AverageCost" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                </div>
                                <span asp-validation-for="Medicine.AverageCost" class="text-danger small"></span>
                            </div>

                            <div class="form-check form-switch mb-3">
                                <input asp-for="Medicine.IsVat" class="form-check-input" type="checkbox" id="vatSwitch" />
                                <label class="form-check-label fw-bold" for="vatSwitch">Apply VAT</label>
                            </div>

                        </div>

                        <div class="col-md-6">
                            <div class="form-group mb-3">
                                <label class="form-label fw-bold">Medicine Image</label>
                                <input type="file" asp-for="ImageFile" class="form-control" accept="image/*" />
                                <small class="form-text text-muted">Upload medicine image (optional)</small>
                                <span asp-validation-for="ImageFile" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label asp-for="Medicine.Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Medicine.Description" class="form-control" rows="3" placeholder="Enter medicine description"></textarea>
                        <span asp-validation-for="Medicine.Description" class="text-danger small"></span>
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-success me-2">
                            <i class="fas fa-save"></i> Save Medicine
                        </button>
                        <a asp-page="./Index" class="btn btn-outline-secondary">
                            <i class="fas fa-arrow-left"></i> Back to List
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        // Client-side validation improvements
        $(document).ready(function () {
            $('form').on('submit', function () {
                $('button[type="submit"]').prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i> Saving...');
            });
        });
    </script>
}






