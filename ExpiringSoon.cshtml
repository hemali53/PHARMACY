@page
@model PHARMACY.Pages.Inventory.ExpiringSoonModel
@{
    ViewData["Title"] = "Expiring Soon";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-4 text-danger">⏰ Expiring Soon</h1>
            <p class="lead">
                Medicines that are expiring within the next 3 or 6 months
            </p>

    <!-- Timeframe Selection -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Select Time Frame</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <a href="?timeFrame=3months&searchString=@Model.SearchString"
                               class="btn @(Model.TimeFrame == "3months" ? "btn-primary" : "btn-outline-primary") btn-lg w-100 mb-2">
                                📅 3 Months View
                            </a>
                        </div>
                        <div class="col-md-6">
                            <a href="?timeFrame=6months&searchString=@Model.SearchString"
                               class="btn @(Model.TimeFrame == "6months" ? "btn-info" : "btn-outline-info") btn-lg w-100 mb-2">
                                📅 6 Months View
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary Cards - MONTHS BASED -->
    <div class="row mt-4">
        <div class="col-md-4 mb-4">
            <div class="card text-white bg-danger">
                <div class="card-body text-center">
                    <h4>Within 3 Months</h4>
                    <h2>@Model.ExpiringIn3Months</h2>
                    <small>Total across all batches</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-info">
                <div class="card-body text-center">
                    <h4>Within 6 Months</h4>
                    <h2>@Model.ExpiringIn6Months</h2>
                    <small>Total across all batches</small>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card text-white bg-secondary">
                <div class="card-body text-center">
                    <h4>Currently Showing</h4>
                    <h2>@Model.TotalExpiring</h2>
                    <small>@(Model.TimeFrame == "6months" ? "6 Months" : "3 Months") View</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="row mt-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5>Filters</h5>
                </div>
                <div class="card-body">
                    <form method="get" class="row">
                        <input type="hidden" name="timeFrame" value="@Model.TimeFrame" />
                        <div class="col-md-6 mb-3">
                            <label for="searchString" class="form-label">Search Medicine</label>
                            <input type="text" class="form-control" id="searchString" name="searchString" value="@Model.SearchString" placeholder="Enter medicine name or batch number...">
                        </div>
                        <div class="col-md-6 mb-3 d-flex align-items-end">
                            <button type="submit" class="btn btn-primary me-2">Apply Filters</button>
                            <a href="/Inventory/ExpiringSoon?timeFrame=@Model.TimeFrame" class="btn btn-outline-secondary">Reset</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Expiring Medicines Table -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5>
                        Expiring Medicines - @(Model.TimeFrame == "6months" ? "6 Months" : "3 Months") View
                        <span class="badge bg-primary">@Model.TotalExpiring Found</span>
                    </h5>
                    <div>
                        <a href="javascript:window.print()" class="btn btn-outline-primary btn-sm me-2">
                            <i class="fas fa-print"></i> Print Report
                        </a>
                        <a href="/Inventory/ExportExpiring?timeFrame=@Model.TimeFrame&searchString=@Model.SearchString" class="btn btn-outline-success btn-sm">
                            <i class="fas fa-download"></i> Export
                        </a>
                    </div>
                </div>
                <div class="card-body">
                    @if (Model.ExpiringMedicines.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Medicine Name</th>
                                        <th>Batch Number</th>
                                        <th>Current Stock</th>
                                        <th>Expiry Date</th>
                                        <th>Expiry Category</th>                                       
                                        @* <th>Purchase Price</th>
                                        <th>Selling Price</th> *@
                                        <th>Stock Value</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.ExpiringMedicines)
                                    {
                                        <tr>
                                            <td>
                                                <strong>@item.MedicineName</strong>
                                                @if (!string.IsNullOrEmpty(item.Description))
                                                {
                                                    <br>
                                                    <small class="text-muted">@item.Description</small>
                                                }
                                            </td>
                                            <td>@item.BatchNumber</td>
                                            <td>
                                                <span class="badge @GetStockBadgeClass(item.CurrentStock)">
                                                    @item.CurrentStock units
                                                </span>
                                            </td>
                                            <td>
                                                <span class="@GetExpiryClass(item.ExpiryDate)">
                                                    @item.ExpiryDate.ToString("MMM dd, yyyy")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="@GetCategoryBadgeClass(item.ExpiryCategory)">
                                                    @item.ExpiryCategory                                           
                                                    </span>
                                                </td>                                                                                                
                                            
                                            @* <td>Rs. @item.PurchasePrice.ToString("N2")</td>
                                            <td>Rs. @item.SellingPrice.ToString("N2")</td> *@
                                            <td>
                                                <strong>Rs. @item.StockValue.ToString("N2")</strong>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm">
                                                    <a href="/Medicines/EditBatch/@item.BatchId" class="btn btn-outline-warning" title="Edit Batch">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                    <a href="/Inventory/StockAdjustment?batchId=@item.BatchId" class="btn btn-outline-info" title="Adjust Stock">
                                                        <i class="fas fa-exchange-alt"></i>
                                                    </a>
                                                    <a href="/Medicines/Details/@item.MedicineId" class="btn btn-outline-primary" title="View Medicine">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </div>
                                            </td>
                                            </tr>                                      
                                    }
                                </tbody>
                            </table>
                        </div>

                        <!-- Alerts based on current view -->
                        @if (Model.TimeFrame == "3months" && Model.ExpiringMedicines.Any(x => x.ExpiryCategory == "3 Months"))
                        {
                            <div class="alert alert-danger mt-4">
                                <h5><i class="fas fa-exclamation-triangle"></i> Urgent Action Required!</h5>
                                <p class="mb-0">You have <strong>@Model.ExpiringMedicines.Count(x => x.ExpiryCategory == "3 Months")</strong> medicines expiring within 3 months. Consider immediate action.</p>
                            </div>
                        }

                        @if (Model.TimeFrame == "6months" && Model.ExpiringMedicines.Any(x => x.ExpiryCategory == "6 Months"))
                        {
                            <div class="alert alert-warning mt-4">
                                <h5><i class="fas fa-exclamation-circle"></i> Planning Required</h5>
                                <p class="mb-0">You have <strong>@Model.ExpiringMedicines.Count(x => x.ExpiryCategory == "6 Months")</strong> medicines expiring within 6 months. Plan for promotions or transfers.</p>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="alert alert-success text-center">
                            <i class="fas fa-check-circle fa-2x mb-3"></i>
                            <h4>No Expiring Medicines Found!</h4>
                            <p class="mb-0">Great! There are no medicines expiring within the @(Model.TimeFrame == "6months" ? "6 months" : "3 months") timeframe.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Recommendations -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5><i class="fas fa-lightbulb"></i> Recommendations</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6">
                            <h6 class="text-danger">For 3 Months Expiry:</h6>
                            <ul>
                                <li>Contact supplier for possible returns</li>
                                <li>Create special promotions or discounts</li>
                                <li>Move to front of shelf for quick sale</li>
                                <li>Consider donation options</li>
                                <li>Notify sales team for priority selling</li>
                            </ul>
                        </div>
                        <div class="col-md-6">
                            <h6 class="text-info">For 6 Months Expiry:</h6>
                            <ul>
                                <li>Review purchasing quantities</li>
                                <li>Implement FIFO (First-In-First-Out) system</li>
                                <li>Set up expiry date alerts</li>
                                <li>Regular inventory audits</li>
                                <li>Plan gradual promotions</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@functions {
    private string GetStockBadgeClass(int currentStock)
    {
        if (currentStock == 0) return "bg-danger";
        if (currentStock <= 10) return "bg-warning";
        return "bg-success";
    }

    private string GetExpiryClass(DateTime expiryDate)
    {
        if (expiryDate <= DateTime.Today.AddMonths(3)) return "text-danger fw-bold";
        if (expiryDate <= DateTime.Today.AddMonths(6)) return "text-warning fw-bold";
        return "text-secondary";
    }

    private string GetCategoryBadgeClass(string expiryCategory)
    {
        switch (expiryCategory)
        {
            case "3 Months":
                return "badge bg-danger";
            case "6 Months":
                return "badge bg-warning";
            default:
                return "badge bg-secondary";
        }
    }

    private string GetDaysBadgeClass(int daysUntilExpiry)
    {
        if (daysUntilExpiry <= 30) return "badge bg-danger";
        if (daysUntilExpiry <= 90) return "badge bg-warning";
        if (daysUntilExpiry <= 180) return "badge bg-info";
        return "badge bg-secondary";
    }
}

<!-- Add Font Awesome for icons -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

<style>
    .card {
        transition: transform 0.2s;
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

    .table th {
        border-top: none;
        font-weight: 600;
        background-color: #343a40;
        color: white;
    }

    .badge {
        font-size: 0.8em;
        padding: 0.4em 0.6em;
    }

    .btn-group-sm > .btn {
        padding: 0.25rem 0.5rem;
    }

    .alert-success {
        background-color: #d1edff;
        border-color: #b6e0ff;
        color: #0c5460;
    }

    @@media print {
        .btn, .card-header .btn, .navbar, .footer, .alert {
            display: none !important;
        }

        .card {
            box-shadow: none !important;
            border: 1px solid #dee2e6 !important;
        }
    }
</style>