@page
@model PHARMACY.Pages.Inventory.StockAdjustmentModel
@{
    ViewData["Title"] = "Stock Adjustment";
    Layout = "_Layout";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h1 class="display-4 text-primary">📊 Stock Adjustment</h1>
            <p class="lead">Adjust stock quantities for damaged, expired or returned items</p>
        </div>
    </div>

    <!-- Success/Error Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle"></i> Please fix the errors below.
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="row mt-4">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fas fa-edit"></i> Adjust Stock</h5>
                </div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.MedicineID" class="form-label">Select Medicine *</label>
                                    <select class="form-select" asp-for="Input.MedicineID" required>
                                        <option value="">Choose Medicine...</option>
                                        @foreach (var medicine in Model.Medicines)
                                        {
                                            <option value="@medicine.Value">@medicine.Text</option>
                                        }
                                    </select>
                                    <span asp-validation-for="Input.MedicineID" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="Input.BatchNumber" class="form-label">Batch Number *</label>
                                    <select class="form-select" asp-for="Input.BatchNumber" required>
                                        <option value="">Select Batch...</option>
                                    </select>
                                    <span asp-validation-for="Input.BatchNumber" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Input.AdjustmentType" class="form-label">Adjustment Type *</label>
                                    <select class="form-select" asp-for="Input.AdjustmentType" required>
                                        <option value="">Select Type...</option>
                                        <option value="Damage">Damage</option>
                                        <option value="Return">Return</option>
                                        <option value="Expired">Expired</option>
                                        <option value="Theft">Theft</option>
                                        <option value="Other">Other</option>
                                    </select>
                                    <span asp-validation-for="Input.AdjustmentType" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Input.Quantity" class="form-label">Quantity *</label>
                                    <input type="number" class="form-control" asp-for="Input.Quantity" min="1" required>
                                    <span asp-validation-for="Input.Quantity" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label asp-for="Input.AdjustmentDate" class="form-label">Date *</label>
                                    <input type="date" class="form-control" asp-for="Input.AdjustmentDate" required>
                                    <span asp-validation-for="Input.AdjustmentDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Input.Reason" class="form-label">Reason *</label>
                            <textarea class="form-control" asp-for="Input.Reason" rows="3" placeholder="Enter reason for stock adjustment..." required></textarea>
                            <span asp-validation-for="Input.Reason" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="fas fa-save"></i> Submit Adjustment
                            </button>
                            <a href="/Inventory" class="btn btn-secondary btn-lg">
                                <i class="fas fa-arrow-left"></i> Back to Inventory
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fas fa-history"></i> Recent Adjustments</h5>
                </div>
                <div class="card-body">
                    <div class="list-group">
                        @if (Model.RecentAdjustments != null && Model.RecentAdjustments.Any())
                        {
                            @foreach (var adj in Model.RecentAdjustments)
                            {
                                <div class="list-group-item">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1 text-primary">@adj.MedicineName</h6>
                                        <small class="text-muted">@adj.AdjustmentDate.ToString("MMM dd, yyyy")</small>
                                    </div>
                                    <p class="mb-1">
                                        <span class="badge
                                                    @(adj.AdjustmentType == "Damage" ? "bg-danger" :
                                                      adj.AdjustmentType == "Expired" ? "bg-warning" :
                                                      adj.AdjustmentType == "Return" ? "bg-success" : "bg-secondary")">
                                    @adj.AdjustmentType
                                </span>
                                - <strong>@adj.Quantity</strong> units
                            </p>
                            <small class="text-muted">@adj.Reason</small>
                        </div>
                                                }
                        }
                        else
                        {
                            <div class="list-group-item text-center">
                                <i class="fas fa-info-circle fa-2x text-muted mb-2"></i>
                                <p class="text-muted mb-1">No recent adjustments found</p>
                                <small class="text-muted">Adjustments will appear here after you make adjustments</small>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.getElementById('Input_MedicineID').addEventListener('change', function() {
            var medicineId = this.value;
            var batchSelect = document.getElementById('Input_BatchNumber');

            if (medicineId) {
                // Show loading
                batchSelect.innerHTML = '<option value="">Loading batches...</option>';

                fetch(`?handler=Batches&medicineId=${medicineId}`)
                    .then(response => {
                        if (!response.ok) {
                            throw new Error('Network response was not ok');
                        }
                        return response.json();
                    })
                    .then(data => {
                        batchSelect.innerHTML = '<option value="">Select Batch...</option>';
                        if (data && data.length > 0) {
                            data.forEach(batch => {
                                batchSelect.innerHTML += `<option value="${batch.batchNumber}">${batch.batchNumber}</option>`;
                            });
                        } else {
                            batchSelect.innerHTML += '<option value="">No batches available</option>';
                        }
                    })
                    .catch(error => {
                        console.error('Error fetching batches:', error);
                        batchSelect.innerHTML = '<option value="">Error loading batches</option>';
                    });
            } else {
                batchSelect.innerHTML = '<option value="">Select Batch...</option>';
            }
        });

        // Set today's date as default
        document.getElementById('Input_AdjustmentDate').valueAsDate = new Date();
    </script>
}

<style>
    .card {
        transition: transform 0.2s;
        border: none;
        border-radius: 10px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }

        .card:hover {
            transform: translateY(-2px);
        }

    .btn {
        border-radius: 8px;
        transition: all 0.3s;
    }

        .btn:hover {
            transform: scale(1.02);
        }

    .list-group-item {
        border: 1px solid #e9ecef;
        border-radius: 8px;
        margin-bottom: 8px;
    }
</style>